# Neon PostgreSQL - Get from https://neon.tech
DATABASE_URL=postgresql+asyncpg://username:password@ep-xxx.us-east-2.aws.neon.tech/analytiq?sslmode=require

# JWT Secret - Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# OpenAI (optional - for AI insights)
OPENAI_API_KEY=

# CORS - Frontend URL
ALLOWED_ORIGINS=["http://localhost:3000","https://your-app.vercel.app"]

# App
DEBUG=false
