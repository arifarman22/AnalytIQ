# ============================================
# AnalytIQ Backend — Environment Variables
# ============================================
# Copy: cp .env.example .env

# ── Database (Neon PostgreSQL) ──
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.neon.tech/analytiq?sslmode=require
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ── JWT Auth ──
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── CORS ──
# Local:

# Production:
# ALLOWED_ORIGINS=["https://analyt-iq.vercel.app"]

# ── OpenAI (optional) ──
OPENAI_API_KEY=

# ── Rate Limiting ──
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_UPLOAD=10/minute
RATE_LIMIT_ANALYSIS=5/minute

# ── App ──
APP_DEBUG=false
MAX_FILE_SIZE=52428800
MAX_PLOTS=6
MAX_ROWS_ANALYSIS=100000

# ── Workers (Docker/Render) ──
WEB_CONCURRENCY=2
