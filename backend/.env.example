# ============================================
# AnalytIQ Backend — Environment Variables
# ============================================
# Copy this file: cp .env.example .env
# Then fill in your actual values below.

# ── Database (Neon PostgreSQL) ──
# Get from https://neon.tech → Project → Connection Details
DATABASE_URL=postgresql+asyncpg://username:password@ep-xxx.us-east-2.aws.neon.tech/analytiq?sslmode=require

# ── JWT Auth ──
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# ── CORS — Frontend URL ──
# Local development:
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
# Production (replace with your actual frontend URL):
# ALLOWED_ORIGINS=["https://analyt-iq.vercel.app"]

# ── OpenAI (optional — for AI insights) ──
OPENAI_API_KEY=

# ── App Settings ──
APP_DEBUG=false
MAX_FILE_SIZE=52428800
MAX_PLOTS=6
